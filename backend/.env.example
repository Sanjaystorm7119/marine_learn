# Database
DATABASE_URL=postgresql://postgres:<password>@localhost/marinelearn_db3

# JWT
JWT_SECRET_KEY=<generate-a-random-secret>

# Microsoft Graph (Teams meeting invitations)
MS_TENANT_ID=<your-azure-tenant-id>
MS_CLIENT_ID=<your-azure-app-client-id>
MS_CLIENT_SECRET=<your-azure-app-client-secret>
MS_ORGANIZER_UPN=<organizer-email@yourdomain.com>
MS_ORGANIZER_NAME=<Organizer Display Name>
